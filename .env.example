# ── Provider: Nvidia NIM (primary — Gemma 4 31B, key from Infisical) ──
# API key is auto-resolved from Infisical at /providers/nvidia → api_key
# No need to set manually unless overriding
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=google/gemma-4-31b-it

# ── Provider: OpenRouter (primary — Gemma 4 31B free tier) ──
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b

# ── Provider: OpenRouter (fallback) ──
# Get your key at https://openrouter.ai/keys

# ── Provider: Cerebras (optional — faster but Gemma access may be limited) ──
# Get your key at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# ── Provider selection ──
# Set to "openrouter" (default) or "cerebras"
LLM_PROVIDER=nvidia_nim

# ── Demo settings ──
DEMO_IMAGE_PATH=examples/images/workspace.jpg
REASONING_EFFORT=none
