# Cerebras API key — get yours at https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your-api-key-here

# OpenRouter API key (free tier for Gemma 4 31B)
OPENROUTER_API_KEY=sk-or-v1-
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b

# Default LLM provider (cerebras | openrouter)
LLM_PROVIDER=cerebras

# Optional: comparison provider (e.g., OpenAI, Groq) for speed benchmarks
COMPARISON_API_KEY=
COMPARISON_BASE_URL=
COMPARISON_MODEL=

# Demo settings
DEMO_IMAGE_PATH=examples/images/workspace.jpg
REASONING_EFFORT=none